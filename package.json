{
  "name": "ai-interview-helper",
  "version": "0.1.0",
  "private": true,
  "description": "AI-Interview-Helper monorepo for AI job interview practice, learning, and intelligence.",
  "packageManager": "npm@10.9.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:web dev:api",
    "dev:web": "npm --workspace @aih/web run dev",
    "dev:api": "npm --workspace @aih/api run start:dev",
    "build": "npm-run-all build:*",
    "build:web": "npm --workspace @aih/web run build",
    "build:api": "npm --workspace @aih/api run build",
    "lint": "npm-run-all lint:*",
    "lint:web": "npm --workspace @aih/web run lint",
    "lint:api": "npm --workspace @aih/api run lint",
    "test": "npm-run-all test:*",
    "test:web": "npm --workspace @aih/web run test",
    "test:api": "npm --workspace @aih/api run test",
    "typecheck": "npm-run-all typecheck:*",
    "typecheck:web": "npm --workspace @aih/web run typecheck",
    "typecheck:api": "npm --workspace @aih/api run typecheck",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "brace-expansion": "^5.0.6",
    "caniuse-lite": "^1.0.30001793",
    "lru-cache": "^11.5.1",
    "npm-run-all": "^4.1.5",
    "pathe": "^2.0.3",
    "prisma": "^6.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "@prisma/client": "^6.1.0",
    "lodash": "^4.18.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  }
}
